import java.io.*;
import java.time.LocalDate;
import java.time.LocalTime;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.*;

class RepairSlot implements Serializable {
    private static final long serialVersionUID = 1L;
    private String slotId, technicianName, day;
    private LocalDate date;
    private LocalTime time;
    private boolean isBooked;

    public RepairSlot(String slotId, String technicianName, String day, LocalDate date, LocalTime time) {
        this.slotId = slotId;
        this.technicianName = technicianName;
        this.day = day;
        this.date = date;
        this.time = time;
        this.isBooked = false;
    }

    public String getSlotId() { return slotId; }
    public void setSlotId(String slotId) { this.slotId = slotId; }
    public String getTechnicianName() { return technicianName; }
    public void setTechnicianName(String technicianName) { this.technicianName = technicianName; }
    public String getDay() { return day; }
    public void setDay(String day) { this.day = day; }
    public LocalDate getDate() { return date; }
    public void setDate(LocalDate date) { this.date = date; }
    public LocalTime getTime() { return time; }
    public void setTime(LocalTime time) { this.time = time; }
    public boolean isBooked() { return isBooked; }
    public void setBooked(boolean booked) { isBooked = booked; }

    @Override
    public String toString() {
        return String.format("Slot ID: %s | Technician: %s | Day: %s | Date: %s | Time: %s | Status: %s",
                slotId, technicianName, day, date, time, isBooked ? "Booked" : "Available");
    }
}

class TechnicianService {
    private static final String SLOT_FILE = "repair_slots.dat";
    private static final DateTimeFormatter DATE_FORMATTER = DateTimeFormatter.ofPattern("yyyy-MM-dd");
    private static final DateTimeFormatter TIME_FORMATTER = DateTimeFormatter.ofPattern("HH:mm");

    public void addRepairSlot(Scanner scanner) {
        try {
            System.out.println("\n=== Add Repair Slot ===");
            System.out.print("Enter Slot ID: ");
            String slotId = scanner.nextLine().trim();
            if (slotId.isEmpty()) {
                System.out.println("Error: Slot ID cannot be empty!"); return;
            }

            List<RepairSlot> slots = loadSlots();
            if (findSlotById(slots, slotId) != null) {
                System.out.println("Error: Slot ID already exists!"); return;
            }

            System.out.print("Enter Technician Name: ");
            String technicianName = scanner.nextLine().trim();
            if (technicianName.isEmpty()) {
                System.out.println("Error: Technician name cannot be empty!"); return;
            }

            System.out.print("Enter Day (e.g., Monday): ");
            String day = scanner.nextLine().trim();
            if (day.isEmpty()) {
                System.out.println("Error: Day cannot be empty!"); return;
            }

            System.out.print("Enter Date (YYYY-MM-DD): ");
            LocalDate date = parseDate(scanner.nextLine().trim());
            if (date == null) return;

            System.out.print("Enter Time (HH:MM): ");
            LocalTime time = parseTime(scanner.nextLine().trim());
            if (time == null) return;

            slots.add(new RepairSlot(slotId, technicianName, day, date, time));
            saveSlots(slots);
            System.out.println("Repair slot added successfully!");
        } catch (Exception e) {
            System.out.println("Error adding repair slot: " + e.getMessage());
        }
    }

    public void viewRepairSlots() {
        try {
            System.out.println("\n=== View Repair Slots ===");
            List<RepairSlot> slots = loadSlots();
            if (slots.isEmpty()) {
                System.out.println("No repair slots available."); return;
            }

            System.out.println("All Repair Slots:\n-------------------------------------------------------------------------------");
            for (int i = 0; i < slots.size(); i++) 
                System.out.println((i + 1) + ". " + slots.get(i));
            System.out.println("-------------------------------------------------------------------------------");
        } catch (Exception e) {
            System.out.println("Error viewing repair slots: " + e.getMessage());
        }
    }

    public void updateRepairSlot(Scanner scanner) {
        try {
            System.out.println("\n=== Update Repair Slot ===");
            System.out.print("Enter Slot ID to update: ");
            String slotId = scanner.nextLine().trim();

            List<RepairSlot> slots = loadSlots();
            RepairSlot slot = findSlotById(slots, slotId);
            if (slot == null) {
                System.out.println("Error: Slot ID not found!"); return;
            }
            if (slot.isBooked()) {
                System.out.println("Error: Cannot update a booked slot!"); return;
            }

            System.out.println("Current slot details:\n" + slot + "\nEnter new details (press enter to keep current value):");
            System.out.print("New Technician Name (" + slot.getTechnicianName() + "): ");
            String techName = scanner.nextLine().trim();
            if (!techName.isEmpty()) slot.setTechnicianName(techName);

            System.out.print("New Day (" + slot.getDay() + "): ");
            String day = scanner.nextLine().trim();
            if (!day.isEmpty()) slot.setDay(day);

            System.out.print("New Date (" + slot.getDate() + "): ");
            String dateStr = scanner.nextLine().trim();
            if (!dateStr.isEmpty()) {
                LocalDate date = parseDate(dateStr);
                if (date != null) slot.setDate(date);
            }

            System.out.print("New Time (" + slot.getTime() + "): ");
            String timeStr = scanner.nextLine().trim();
            if (!timeStr.isEmpty()) {
                LocalTime time = parseTime(timeStr);
                if (time != null) slot.setTime(time);
            }

            saveSlots(slots);
            System.out.println("Repair slot updated successfully!");
        } catch (Exception e) {
            System.out.println("Error updating repair slot: " + e.getMessage());
        }
    }

    public void deleteRepairSlot(Scanner scanner) {
        try {
            System.out.println("\n=== Delete Repair Slot ===");
            System.out.print("Enter Slot ID to delete: ");
            String slotId = scanner.nextLine().trim();

            List<RepairSlot> slots = loadSlots();
            RepairSlot slot = findSlotById(slots, slotId);
            if (slot == null) {
                System.out.println("Error: Slot ID not found!"); return;
            }
            if (slot.isBooked()) {
                System.out.println("Error: Cannot delete a booked slot!"); return;
            }

            System.out.println("Slot to be deleted:\n" + slot);
            System.out.print("Are you sure you want to delete this slot? (yes/no): ");
            if (scanner.nextLine().trim().equalsIgnoreCase("yes")) {
                slots.remove(slot);
                saveSlots(slots);
                System.out.println("Repair slot deleted successfully!");
            } else System.out.println("Deletion cancelled.");
        } catch (Exception e) {
            System.out.println("Error deleting repair slot: " + e.getMessage());
        }
    }

    private RepairSlot findSlotById(List<RepairSlot> slots, String slotId) {
        return slots.stream().filter(s -> s.getSlotId().equalsIgnoreCase(slotId)).findFirst().orElse(null);
    }

    private LocalDate parseDate(String input) {
        try { return LocalDate.parse(input, DATE_FORMATTER); } 
        catch (DateTimeParseException e) {
            System.out.println("Error: Invalid date format. Please use YYYY-MM-DD."); return null;
        }
    }

    private LocalTime parseTime(String input) {
        try { return LocalTime.parse(input, TIME_FORMATTER); } 
        catch (DateTimeParseException e) {
            System.out.println("Error: Invalid time format. Please use HH:MM."); return null;
        }
    }

    @SuppressWarnings("unchecked")
    private List<RepairSlot> loadSlots() {
        File file = new File(SLOT_FILE);
        if (!file.exists()) return new ArrayList<>();
        try (ObjectInputStream ois = new ObjectInputStream(new FileInputStream(SLOT_FILE))) {
            return (List<RepairSlot>) ois.readObject();
        } catch (Exception e) {
            System.out.println("Error loading slots: " + e.getMessage()); return new ArrayList<>();
        }
    }

    private void saveSlots(List<RepairSlot> slots) {
        try (ObjectOutputStream oos = new ObjectOutputStream(new FileOutputStream(SLOT_FILE))) {
            oos.writeObject(slots);
        } catch (Exception e) {
            System.out.println("Error saving slots: " + e.getMessage());
        }
    }
}

public class TechnicianMenu {
    private TechnicianService technicianService = new TechnicianService();
    private Scanner scanner = new Scanner(System.in);

    public void showMenu() {
        while (true) {
            System.out.println("\n=== Technician Menu ===\n1. Add Repair Slot\n2. View Repair Slots\n3. Update Repair Slot\n4. Delete Repair Slot\n5. Exit to Main Menu");
            System.out.print("Please choose an option (1-5): ");
            int choice = getIntInput();
            switch (choice) {
                case 1: technicianService.addRepairSlot(scanner); break;
                case 2: technicianService.viewRepairSlots(); break;
                case 3: technicianService.updateRepairSlot(scanner); break;
                case 4: technicianService.deleteRepairSlot(scanner); break;
                case 5: System.out.println("Returning to main menu..."); return;
                default: System.out.println("Invalid choice. Please enter a number between 1-5.");
            }
            System.out.print("Press enter to continue...");
            scanner.nextLine();
        }
    }

    private int getIntInput() {
        try { return Integer.parseInt(scanner.nextLine()); } 
        catch (NumberFormatException e) { return -1; }
    }

    public static void main(String[] args) {
        new TechnicianMenu().showMenu();
    }
}
